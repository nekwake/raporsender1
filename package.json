{
  "name": "bridge-v1",
  "version": "1.0.0",
  "description": "Bridge V1: Excel/PDF table preparation and transfer",
  "main": "main_paste.js",
  "scripts": {
    "start": "electron .",
    "test": "echo \"No tests configured\"",
    "build:win": "electron-builder --win nsis",
    "build:mac": "electron-builder --mac dmg"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nekwake/raporsender1.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/nekwake/raporsender1/issues"
  },
  "homepage": "https://github.com/nekwake/raporsender1#readme",
  "dependencies": {
    "chokidar": "^5.0.0",
    "fs-extra": "^11.3.4",
    "pdf-parse": "^2.4.5",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.bridgev1.app",
    "productName": "Bridge V1",
    "files": [
      "main_paste.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "assets/**",
      "node_modules/**",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1"
  }
}
